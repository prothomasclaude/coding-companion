{
  "name": "Peon",
  "author": "Spriters Resource",
  "framePattern": "peon_{n}.png",
  "display": { "width": 102, "height": 129 },
  "animations": {
    "idle": { "frames": [0, 0], "speed": 180 },
    "waiting": { "frames": [1, 4], "speed": 140 },
    "working": { "frames": [5, 9], "speed": 100 },
    "finished": { "frames": [10, 14], "speed": 150 },
    "victory": { "frames": [15, 19], "speed": 160 }
  },
  "states": {
    "idle": {
      "animation": "idle",
      "loop": true
    },
    "working": {
      "animations": ["waiting", "working"],
      "loop": true,
      "swapInterval": 3000
    },
    "finished": {
      "animation": "finished",
      "loop": true,
      "duration": 4000,
      "then": {
        "animation": "victory",
        "loop": false,
        "thenIdle": true
      }
    }
  },
  "lines": {
    "idle": [
      { "text": "Something need doing?", "sound": "sounds/PeonWhat1.wav" },
      { "text": "Me busy, leave me alone!", "sound": "sounds/PeonWhat2.wav" },
      { "text": "Hmmm?", "sound": "sounds/PeonWhat3.wav" },
      { "text": "What you want?", "sound": "sounds/PeonWhat4.wav" }
    ],
    "working": [
      { "text": "Okie dokie.", "sound": "sounds/PeonYes1.wav" },
      { "text": "Zug zug.", "sound": "sounds/PeonYes2.wav" },
      { "text": "Dabu.", "sound": "sounds/PeonYes3.wav" },
      { "text": "Work work...", "sound": "sounds/PeonYes4.wav" }
    ],
    "finished": [
      { "text": "Work complete!", "sound": "sounds/PeonWorkComplete.wav" },
      { "text": "STOP POKING ME!", "sound": "sounds/PeonAngry1.wav" },
      { "text": "Me not that kind of orc!", "sound": "sounds/PeonAngry2.wav" }
    ],
    "greeting": [
      { "text": "Ready to work!", "sound": "sounds/PeonReady1.wav" }
    ],
    "victory": [
      { "text": "Work complete!", "sound": "sounds/PeonWorkComplete.wav" },
      { "text": "WAAAGH!", "sound": "sounds/PeonWarcry1.wav" }
    ]
  },
  "effects": {
    "thinkingAura": true,
    "poseParticles": true,
    "particleColor": "#8B4513"
  },
  "hitArea": { "x": 6, "y": 6, "width": 90, "height": 117 },
  "preview": "peon_0.png"
}
