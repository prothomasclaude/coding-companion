{
  "name": "Peon",
  "author": "Spriters Resource",
  "framePattern": "peon_{n}.png",
  "display": { "width": 34, "height": 43 },
  "animations": {
    "idle": { "frames": [0, 0], "speed": 180 },
    "waiting": { "frames": [1, 4], "speed": 140 },
    "working": { "frames": [5, 9], "speed": 100 },
    "finished": { "frames": [10, 14], "speed": 150 },
    "victory": { "frames": [15, 19], "speed": 160 }
  },
  "states": {
    "idle": {
      "animation": "idle",
      "loop": true
    },
    "working": {
      "animations": ["waiting", "working"],
      "loop": true,
      "swapInterval": 3000
    },
    "finished": {
      "animation": "finished",
      "loop": true,
      "duration": 4000,
      "then": {
        "animation": "victory",
        "loop": false,
        "thenIdle": true
      }
    }
  },
  "messages": {
    "idle": ["Ready to work.", "Something need doing?", "Zug zug.", "Dabu."],
    "working": [
      "Work work...",
      "Me busy, leave me alone!",
      "Zug zug.",
      "...",
      "Okie dokie."
    ],
    "finished": [
      "STOP POKING ME!",
      "Me not that kind of orc!",
      "Work work work...",
      "Work complete!"
    ],
    "greeting": ["Something need doing?"]
  },
  "sounds": {
    "idle": [
      "sounds/PeonWhat1.wav",
      "sounds/PeonWhat2.wav",
      "sounds/PeonWhat3.wav",
      "sounds/PeonWhat4.wav"
    ],
    "working": [
      "sounds/PeonYes1.wav",
      "sounds/PeonYes2.wav",
      "sounds/PeonYes3.wav",
      "sounds/PeonYes4.wav",
      "sounds/PeonYesAttack3.wav"
    ],
    "finished": [
      "sounds/PeonWorkComplete.wav",
      "sounds/PeonAngry1.wav",
      "sounds/PeonAngry2.wav",
      "sounds/PeonAngry3.wav",
      "sounds/PeonAngry4.wav"
    ],
    "greeting": [
      "sounds/PeonReady1.wav",
      "sounds/PeonWhat4.wav"
    ],
    "victory": [
      "sounds/PeonWorkComplete.wav",
      "sounds/PeonWarcry1.wav"
    ]
  },
  "effects": {
    "thinkingAura": true,
    "poseParticles": true,
    "particleColor": "#8B4513"
  },
  "hitArea": { "x": 16, "y": 15, "width": 90, "height": 105 },
  "preview": "peon_0.png"
}
