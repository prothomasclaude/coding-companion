{
  "name": "Peon",
  "author": "Spriters Resource",
  "framePattern": "peon_{n}.png",
  "display": { "width": 122, "height": 135 },
  "animations": {
    "idle": { "frames": [0, 4], "speed": 180 },
    "waiting": { "frames": [5, 9], "speed": 140 },
    "working": { "frames": [25, 34], "speed": 100 },
    "finished": { "frames": [10, 14], "speed": 150 },
    "victory": { "frames": [50, 54], "speed": 160 }
  },
  "states": {
    "idle": {
      "animation": "idle",
      "loop": true
    },
    "working": {
      "animations": ["waiting", "working"],
      "loop": true,
      "swapInterval": 3000
    },
    "finished": {
      "animation": "finished",
      "loop": true,
      "duration": 4000,
      "then": {
        "animation": "victory",
        "loop": false,
        "thenIdle": true
      }
    }
  },
  "messages": {
    "idle": ["Ready to work.", "Something need doing?", "Zug zug.", "Dabu."],
    "working": [
      "Work work...",
      "Me busy, leave me alone!",
      "Zug zug.",
      "...",
      "Okie dokie."
    ],
    "finished": [
      "STOP POKING ME!",
      "Me not that kind of orc!",
      "Work work work...",
      "Work complete!"
    ],
    "greeting": ["Something need doing?"]
  },
  "effects": {
    "thinkingAura": true,
    "poseParticles": true,
    "particleColor": "#8B4513"
  },
  "hitArea": { "x": 16, "y": 15, "width": 90, "height": 105 },
  "preview": "peon_0.png"
}
