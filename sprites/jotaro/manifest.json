      "duration": 5000,
      "then": {
        "animation": "victory",
        "loop": false,
        "thenIdle": true
      }
    }
  },
  "messages": {
    "idle": ["やれやれだぜ...", "...", "Waiting."],
    "thinking": ["やれやれだぜ...", "Yare yare daze...", "...", "Good grief...", "Working on it.", "Star Platinum!"],
    "pose": ["ORA ORA ORA ORA!", "STAR PLATINUM!", "ORA!", "ORAORAORAORAORA!"],
    "greeting": ["やれやれだぜ..."]
  },
  "effects": {
    "thinkingAura": true,
    "poseParticles": true,
    "particleColor": "#ffd700"
  },
  "hitArea": { "x": 140, "y": 55, "width": 165, "height": 130 },
