{
  "name": "Jotaro Kujo",
  "author": "Spriters Resource",
  "framePattern": "Jot_0-{n}.png",
  "display": { "width": 384, "height": 224 },
  "animations": {
    "idle":     { "frames": [0, 17],    "speed": 120 },
    "waiting":  { "frames": [40, 50],   "speed": 100 },
    "working":  { "frames": [550, 558], "speed": 140 },
    "finished": { "frames": [700, 712], "speed": 80  },
    "victory":  { "frames": [160, 172], "speed": 120 }
  },
  "states": {
    "idle": {
      "animation": "idle",
      "loop": true
    },
    "working": {
      "animations": ["waiting", "working"],
      "loop": true,
      "swapInterval": 3000
    },
    "finished": {
      "animation": "finished",
      "loop": true,
      "duration": 4000,
      "then": {
        "animation": "victory",
        "loop": false,
        "thenIdle": true
      }
    }
  },
  "messages": {
    "idle": ["やれやれだぜ...", "...", "Waiting."],
    "working": ["やれやれだぜ...", "Yare yare daze...", "...", "Good grief...", "Working on it.", "Star Platinum!"],
    "finished": ["ORA ORA ORA ORA!", "STAR PLATINUM!", "ORA!", "ORAORAORAORAORA!"],
    "greeting": ["やれやれだぜ..."]
  },
  "sounds": {
    "idle": ["sounds/Taunt 1.wav", "sounds/Taunt 2.wav"],
    "working": ["sounds/Stand On.wav", "sounds/Star Finger 1.wav", "sounds/Super Charge.wav"],
    "finished": ["sounds/Ora 1.wav", "sounds/Blazing Fists.wav", "sounds/Star Breaker.wav"],
    "greeting": ["sounds/Intro.wav"],
    "victory": ["sounds/Win 1.wav", "sounds/Win 2_1.wav"]
  },
  "effects": {
    "thinkingAura": true,
    "poseParticles": true,
    "particleColor": "#ffd700"
  },
  "hitArea": { "x": 140, "y": 55, "width": 165, "height": 130 },
  "preview": "Jot_0-0.png"
}
