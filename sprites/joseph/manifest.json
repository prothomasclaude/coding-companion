    "working": ["sounds/joseph_hermitpurple.wav", "sounds/joseph_hermit.wav", "sounds/joseph_overdrive.wav"],
    "finished": ["sounds/joseph_attack1.wav", "sounds/joseph_attack2.wav", "sounds/joseph_attack3.wav", "sounds/joseph_attack4.wav", "sounds/joseph_attack5.wav"],
    "greeting": ["sounds/joseph_roundstart1.wav", "sounds/joseph_roundstart2.wav", "sounds/joseph_roundstart3.wav"],
    "victory": ["sounds/joseph_taunt1.wav", "sounds/joseph_taunt2.wav"]
