{
  "name": "Joseph Joestar",
  "author": "Spriters Resource",
  "framePattern": "JosephJoestar_0-{n}.png",
  "display": { "width": 384, "height": 224 },
  "animations": {
    "idle":     { "frames": [0, 18],    "speed": 120 },
    "waiting":  { "frames": [60, 80],   "speed": 100 },
    "working":  { "frames": [200, 218], "speed": 140 },
    "finished": { "frames": [300, 320], "speed": 80  },
    "victory":  { "frames": [700, 720], "speed": 120 }
  },
  "states": {
    "idle": {
      "animation": "idle",
      "loop": true
    },
    "working": {
      "animations": ["waiting", "working"],
