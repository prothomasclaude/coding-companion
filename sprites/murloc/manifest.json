{
  "name": "Murloc",
  "author": "Freakyplanet (Spriters Resource)",
  "framePattern": "murloc_{n}.png",
  "display": { "width": 240, "height": 220 },
  "displayScale": 6,
  "animations": {
    "idle":     { "frames": [0, 0],   "speed": 300 },
    "waiting":  { "frames": [1, 3],   "speed": 150 },
    "working":  { "frames": [4, 6],   "speed": 120 },
    "finished": { "frames": [7, 9],   "speed": 100 },
    "victory":  { "frames": [10, 12], "speed": 200 }
  },
  "states": {
    "idle": {
      "animation": "idle",
      "loop": true
    },
    "working": {
      "animations": ["waiting", "working"],
      "loop": true,
      "swapInterval": 3000
    },
    "finished": {
      "animation": "finished",
      "loop": true,
      "duration": 4000,
      "then": {
        "animation": "victory",
        "loop": false,
        "thenIdle": true
      }
    }
  },
  "messages": {
    "idle": ["Mrglglgl...", "...", "Aaaaaughibbrgubugbugrguburgle!"],
    "working": ["Mrglglglgl!", "Mrgllll...", "...", "Rwlrwlrwl!", "Mrgl?"],
    "finished": ["MRGLGLGLGL!", "AAAAAUGHIBBRGUBUGBUGRGUBURGLE!", "RWLRWLRWLRWL!", "MRGLLLL!"],
    "greeting": ["Mrglglglgl!"]
  },
  "effects": {
    "thinkingAura": true,
    "poseParticles": true,
    "particleColor": "#00ccff"
  },
  "hitArea": { "x": 50, "y": 30, "width": 140, "height": 160 },
  "preview": "murloc_0.png"
}
